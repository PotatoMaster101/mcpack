# Tags tree that is being chopped by detecting leaves

# 2 blocks
execute at @s if block ~ ~2 ~ #minecraft:leaves run tag @s add istree
execute at @s if block ~-1 ~2 ~-1 #minecraft:leaves run tag @s add istree
execute at @s if block ~1 ~2 ~1 #minecraft:leaves run tag @s add istree

